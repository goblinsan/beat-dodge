{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beat-dodge.dev/schemas/camera-action.schema.json",
  "title": "Beat Dodge Camera Action Event",
  "description": "Sparse gameplay actions emitted by the camera input service.",
  "type": "object",
  "required": ["timestamp_ms", "players"],
  "properties": {
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "players": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "action", "confidence"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2
          },
          "action": {
            "type": "string",
            "enum": ["jump", "duck", "dodge_left", "dodge_right"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
