{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beat-dodge.dev/schemas/course.schema.json",
  "title": "Beat Dodge Course",
  "description": "Timeline data generated from song analysis and consumed by gameplay.",
  "type": "object",
  "required": ["version", "song", "events"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema-compatible course format version."
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "normal", "hard"],
      "description": "Difficulty profile used to generate prompt density and move selection."
    },
    "song": {
      "type": "object",
      "required": ["id", "bpm", "duration_seconds"],
      "properties": {
        "id": { "type": "string" },
        "bpm": { "type": "number", "exclusiveMinimum": 0 },
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time_seconds", "player", "move", "intensity"],
        "properties": {
          "time_seconds": { "type": "number", "minimum": 0 },
          "player": {
            "type": "string",
            "enum": ["player_1", "player_2"],
            "description": "Which player this prompt targets."
          },
          "move": {
            "type": "string",
            "enum": ["dodge_left", "dodge_right", "jump", "duck"],
            "description": "Kid-friendly movement action the player must perform."
          },
          "intensity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Difficulty/energy level derived from song analysis (1 = low, 5 = high)."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
